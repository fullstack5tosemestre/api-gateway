{
  "family": "task-gateway",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "taskRoleArn": "$LAB_ROLE_ARN",
  "executionRoleArn": "$LAB_ROLE_ARN",
  "containerDefinitions": [
    {
      "name": "gateway",
      "image": "$ECR_REPO_URL_API_GATEWAY:latest",
      "portMappings": [
        { "name": "gateway-9090", "containerPort": 9090, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "INVENTORY_IP",          "value": "$INTERNAL_ALB_DNS" },
        { "name": "ORDERS_IP",             "value": "$INTERNAL_ALB_DNS" },
        { "name": "USERS_IP",              "value": "$INTERNAL_ALB_DNS" },
        { "name": "MICROSERVICE_PORT",     "value": "80" },
        { "name": "CORS_ALLOWED_ORIGINS",  "value": "http://$ALB_DNS_NAME" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/task-gateway",
          "awslogs-region": "$AWS_REGION",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
